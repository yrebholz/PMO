/* ====== MAIN NAV BAR ====== */

.pmo-main-nav {
  background: #2F5597;
  padding: 4px 24px; /* taller bar */
  font-family: "Segoe UI Light", "Segoe UI", "Segoe", Tahoma, sans-serif;
}

.pmo-main-nav-root {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  gap: 20px;
  align-items: stretch;
}

.pmo-main-nav-root > li {
  position: relative;
}

/* Top-level links */
.pmo-main-nav-root > li > a {
  display: block;
  padding: 14px 10px;               /* taller clickable area */
  color: #ffffff;
  text-decoration: none;
  font-size: 15px;                  /* larger font */
  font-weight: 400;
  white-space: nowrap;
  font-family: "Segoe UI Light", "Segoe UI", "Segoe", Tahoma, sans-serif;
}

.pmo-main-nav-root > li > a:hover {
  text-decoration: underline;
}

/* Active/current page indicator */
.pmo-main-nav-root > li.pmo-active > a {
  background: #23407a;
  border-radius: 4px;
  text-decoration: none;
}

.pmo-main-nav-root > li.pmo-active > a:hover {
  text-decoration: underline;
}

/* If a top-level item has an active child (e.g. Templates child),
   we highlight the parent as well. */
.pmo-main-nav-root > li.pmo-active-parent > a {
  background: #23407a;
  border-radius: 4px;
}

/* Header-style items (no URL) may appear slightly dimmer;
   JS sets opacity + cursor for them. */

/* ====== MEGAMENU TRIGGER INDICATOR (Templates) ====== */

.pmo-main-nav-root > li.pmo-has-mega > a::after {
  content: " ▾";
  font-size: 10px;
  margin-left: 4px;
}

/* Optional: emphasize Templates on hover */
.pmo-main-nav-root > li.pmo-has-mega:hover > a {
  text-decoration: underline;
}

/* ====== MEGAMENU PANEL FOR TEMPLATES ====== */

.pmo-main-nav-root > li.pmo-has-mega {
  position: relative;
}

.pmo-mega-panel {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  padding: 16px 18px 14px;
  background: #ffffff;
  border-radius: 8px;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25);
  min-width: 720px;
  max-width: 1080px;
  z-index: 1000;
  font-family: "Segoe UI", Tahoma, sans-serif;
}

/* Show the mega panel when hovering the Templates item */
.pmo-main-nav-root > li.pmo-has-mega:hover > .pmo-mega-panel {
  display: block;
}

/* Group columns inside mega panel (one per ProcessGroup) */
.pmo-mega-groups {
  display: flex;
  flex-wrap: nowrap;
  gap: 18px;
}

/* Each Process Group column */
.pmo-mega-group {
  min-width: 140px;
}

/* Process Group title */
.pmo-mega-group-title {
  font-size: 13px;
  font-weight: 700;
  color: #2F5597;
  margin-bottom: 6px;
  border-bottom: 1px solid #dde2ee;
  padding-bottom: 3px;
}

/* Knowledge Area sections inside each Process Group */
.pmo-mega-area {
  margin-bottom: 10px;
}

.pmo-mega-area-title {
  font-size: 12px;
  font-weight: 600;
  color: #333;
  margin-bottom: 2px;
}

/* List of templates inside a Knowledge Area */
.pmo-mega-area-items {
  list-style: none;
  margin: 0;
  padding: 0;
}

.pmo-mega-area-items li a {
  display: block;
  font-size: 12px;
  color: #444;
  text-decoration: none;
  padding: 2px 0;
}

.pmo-mega-area-items li a:hover {
  text-decoration: underline;
}

/* Highlight an active leaf link inside the mega menu (same page) */
.pmo-mega-area-items li.pmo-active-leaf > a {
  font-weight: 600;
  color: #2F5597;
}

/* ====== RESPONSIVE TWEAKS ====== */

@media (max-width: 768px) {
  .pmo-main-nav-root {
    flex-wrap: wrap;
    gap: 10px;
  }

  .pmo-main-nav-root > li.pmo-has-mega {
    position: static;
  }

  .pmo-mega-panel {
    position: static;
    box-shadow: none;
    border-radius: 0;
    margin-top: 6px;
    min-width: auto;
    max-width: none;
  }

  .pmo-mega-groups {
    flex-direction: column;
  }
}



// /Style Library/PMO/Navigation/megamenu.js
// Navigation + Templates megamenu driven by "Navigation" list
// Now with active/current-page highlighting.

function InitPMOMegaMenu() {
  try {
    console.log("PMO MegaMenu: Init starting...");

    var navContainer = document.getElementById("pmoMegaNav");
    if (!navContainer) {
      console.warn("PMO MegaMenu: #pmoMegaNav not found on page.");
      return;
    }

    // Determine site URL (works with/without _spPageContextInfo)
    var siteUrl = (typeof _spPageContextInfo !== "undefined" && _spPageContextInfo.webAbsoluteUrl)
      ? _spPageContextInfo.webAbsoluteUrl
      : window.location.origin + window.location.pathname.replace(/\/Pages\/.*/i, "");

    var listTitle = "Navigation";

    // NOTE: "URL" must match the *internal* name of your hyperlink column
    var requestUrl = siteUrl +
      "/_api/web/lists/getbytitle('" + listTitle + "')/items" +
      "?$select=Id,Title,URL,NavArea,IsTopLevel,ProcessGroup,KnowledgeArea,SortOrder" +
      "&$orderby=SortOrder,Title";

    console.log("PMO MegaMenu: REST URL =", requestUrl);

    // ---------- Helpers ----------

    function getJSON(url, onSuccess, onError) {
      var xhr = new XMLHttpRequest();
      xhr.open("GET", url, true);
      xhr.setRequestHeader("Accept", "application/json;odata=nometadata");
      xhr.onreadystatechange = function () {
        if (xhr.readyState !== 4) return;
        if (xhr.status >= 200 && xhr.status < 300) {
          try {
            var data = JSON.parse(xhr.responseText);
            onSuccess(data);
          } catch (e) {
            console.error("PMO MegaMenu: JSON parse error", e);
            if (onError) onError(e);
          }
        } else {
          console.error("PMO MegaMenu: HTTP", xhr.status, xhr.statusText);
          if (onError) onError(xhr.statusText || ("HTTP " + xhr.status));
        }
      };
      xhr.send();
    }

    function groupBy(arr, fn) {
      var map = {};
      (arr || []).forEach(function (item) {
        var key = fn(item) || "";
        if (!map[key]) map[key] = [];
        map[key].push(item);
      });
      return map;
    }

    function isTrue(val) {
      return val === true || val === "true" || val === 1 || val === "1";
    }

    function getUrlFromField(field) {
      if (!field) return "";
      if (typeof field === "string") return field;
      if (field.Url) return field.Url;
      if (field.url) return field.url;
      return "";
    }

    // Matches helper (for closest polyfill)
    function matches(el, selector) {
      if (!el || el.nodeType !== 1) return false;
      var p = Element.prototype;
      var f = p.matches || p.msMatchesSelector || p.webkitMatchesSelector || p.mozMatchesSelector;
      return f ? f.call(el, selector) : false;
    }

    function closest(el, selector) {
      while (el && el.nodeType === 1) {
        if (matches(el, selector)) return el;
        el = el.parentNode;
      }
      return null;
    }

    // ---------- Active-state logic ----------

    function markActive(navRoot) {
      try {
        var current = window.location.href.toLowerCase().split("#")[0];

        var links = navRoot.querySelectorAll("a[href]");
        var bestLink = null;
        var bestLength = 0;

        for (var i = 0; i < links.length; i++) {
          var a = links[i];
          var href = (a.href || "").toLowerCase().split("#")[0];

          if (!href ||
              href === "javascript:void(0)" ||
              href === "javascript:void(0);") {
            continue;
          }

          // Simple prefix match: current URL starts with link URL
          if (current.indexOf(href) === 0 && href.length > bestLength) {
            bestLength = href.length;
            bestLink = a;
          }
        }

        if (!bestLink) {
          console.log("PMO MegaMenu: no active link match found.");
          return;
        }

        // Mark the direct LI as active
        var li = closest(bestLink, "li");
        if (li) {
          li.classList.add("pmo-active");
          if (closest(li, ".pmo-mega-panel")) {
            // This is a child in the mega menu; mark parent top-level
            var parentMega = closest(li, "li.pmo-has-mega");
            if (parentMega) {
              parentMega.classList.add("pmo-active-parent");
            }
            // Also mark the leaf itself
            li.classList.add("pmo-active-leaf");
          }
        }
      } catch (e) {
        console.warn("PMO MegaMenu: markActive error", e);
      }
    }

    // ---------- Templates mega-menu builder ----------

    function buildTemplatesPanel(children) {
      var byProcess = groupBy(children, function (i) { return i.ProcessGroup; });

      var panel = document.createElement("div");
      panel.className = "pmo-mega-panel";

      var wrapper = document.createElement("div");
      wrapper.className = "pmo-mega-groups";

      Object.keys(byProcess).sort().forEach(function (pg) {
        var pgItems = byProcess[pg];
        if (!pgItems || !pgItems.length) return;

        var pgDiv = document.createElement("div");
        pgDiv.className = "pmo-mega-group";

        var pgTitle = document.createElement("div");
        pgTitle.className = "pmo-mega-group-title";
        pgTitle.textContent = pg || "Other";
        pgDiv.appendChild(pgTitle);

        var byKA = groupBy(pgItems, function (i) { return i.KnowledgeArea; });

        Object.keys(byKA).sort().forEach(function (ka) {
          var kaItems = byKA[ka];
          if (!kaItems || !kaItems.length) return;

          var kaDiv = document.createElement("div");
          kaDiv.className = "pmo-mega-area";

          var kaTitle = document.createElement("div");
          kaTitle.className = "pmo-mega-area-title";
          kaTitle.textContent = ka || "General";
          kaDiv.appendChild(kaTitle);

          var ul = document.createElement("ul");
          ul.className = "pmo-mega-area-items";

          kaItems.forEach(function (t) {
            var urlVal = getUrlFromField(t.URL) || "#";

            var li = document.createElement("li");
            var a = document.createElement("a");
            a.href = urlVal;
            a.textContent = t.Title || urlVal;
            li.appendChild(a);
            ul.appendChild(li);
          });

          kaDiv.appendChild(ul);
          pgDiv.appendChild(kaDiv);
        });

        wrapper.appendChild(pgDiv);
      });

      panel.appendChild(wrapper);
      return panel;
    }

    // ---------- Main nav builder ----------

    function buildNav(items) {
      console.log("PMO MegaMenu: item count =", items.length);
      if (!items || !items.length) {
        navContainer.innerHTML =
          "<div style='color:red;padding:6px'>Navigation list '" + listTitle + "' has no items.</div>";
        return;
      }

      // Top-level items are those with IsTopLevel = Yes
      var topLevel = items.filter(function (i) { return isTrue(i.IsTopLevel); });

      if (!topLevel.length) {
        navContainer.innerHTML =
          "<div style='color:red;padding:6px'>No items in '" + listTitle + "' have IsTopLevel = Yes.</div>";
        return;
      }

      // Templates children: NavArea = "Templates" and not IsTopLevel
      var templatesChildren = items.filter(function (i) {
        return i.NavArea === "Templates" && !isTrue(i.IsTopLevel);
      });

      var nav = document.createElement("nav");
      nav.className = "pmo-main-nav";

      var ul = document.createElement("ul");
      ul.className = "pmo-main-nav-root";

      topLevel.forEach(function (top) {
        var area = top.NavArea;
        var li = document.createElement("li");

        // Determine if this top-level item has a usable URL
        var rawUrl = getUrlFromField(top.URL);
        var hasUrl = rawUrl && rawUrl.trim() !== "";

        var a = document.createElement("a");
        a.textContent = top.Title || area;

        // Base styling (CSS also handles this)
        a.style.display = "block";
        a.style.padding = "14px 10px";
        a.style.color = "#ffffff";
        a.style.textDecoration = "none";
        a.style.fontSize = "15px";
        a.style.fontWeight = "400";

        if (hasUrl) {
          a.href = rawUrl;
        } else {
          // Header-only behavior: no navigation
          a.href = "javascript:void(0)";
          a.style.cursor = "default";
          a.style.opacity = "0.9";

          a.addEventListener("click", function (e) {
            e.preventDefault();
          });
        }

        li.appendChild(a);

        // Attach mega-menu to Templates if it has children
        if (area === "Templates" && templatesChildren.length) {
          li.classList.add("pmo-has-mega");
          li.appendChild(buildTemplatesPanel(templatesChildren));
        }

        ul.appendChild(li);
      });

      nav.appendChild(ul);
      navContainer.innerHTML = "";
      navContainer.appendChild(nav);

      // After nav is in the DOM, calculate active link
      markActive(nav);
    }

    // ---------- Fetch and build ----------

    getJSON(requestUrl, function (data) {
      var items = data && data.value ? data.value : [];
      console.log("PMO MegaMenu: sample item =", items[0]);
      buildNav(items);
    }, function (err) {
      console.error("PMO MegaMenu: error loading list '" + listTitle + "':", err);
      navContainer.innerHTML =
        "<div style='color:red;padding:6px'>Error loading navigation from list '" + listTitle + "'.</div>";
    });

  } catch (ex) {
    console.error("PMO MegaMenu: fatal error", ex);
  }
}

// SharePoint on-load wiring (classic + MDS)
if (typeof _spBodyOnLoadFunctionNames !== "undefined") {
  _spBodyOnLoadFunctionNames.push("InitPMOMegaMenu");
}
if (typeof RegisterModuleInit === "function") {
  RegisterModuleInit(
    "~sitecollection/Style Library/PMO/Navigation/megamenu.js",
    InitPMOMegaMenu
  );
}

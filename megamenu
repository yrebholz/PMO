/* ====== MAIN NAV BAR ====== */

.pmo-main-nav {
  background: #2F5597;
  padding: 0 16px;
  font-family: "Segoe UI", Helvetica, Arial, sans-serif;
}

.pmo-main-nav-root {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  gap: 18px;
  align-items: stretch;
}

.pmo-main-nav-root > li {
  position: relative;
}

/* Top-level links */
.pmo-main-nav-root > li > a {
  display: block;
  padding: 10px 4px;
  color: #ffffff;
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
  white-space: nowrap;
}

.pmo-main-nav-root > li > a:hover {
  text-decoration: underline;
}

/* Header-style items (no URL) will get cursor: default from JS.
   If you want a slightly different look, you can target them with a class later. */

/* ====== MEGAMENU TRIGGER INDICATOR (Templates) ====== */

.pmo-main-nav-root > li.pmo-has-mega > a::after {
  content: " ▾";
  font-size: 10px;
  margin-left: 4px;
}

/* Optional: emphasize Templates on hover */
.pmo-main-nav-root > li.pmo-has-mega:hover > a {
  text-decoration: underline;
}

/* ====== MEGAMENU PANEL FOR TEMPLATES ====== */

.pmo-main-nav-root > li.pmo-has-mega {
  position: relative;
}

.pmo-mega-panel {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  padding: 16px 18px 14px;
  background: #ffffff;
  border-radius: 8px;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25);
  min-width: 720px;
  max-width: 1080px;
  z-index: 1000;
}

/* Show the mega panel when hovering the Templates item */
.pmo-main-nav-root > li.pmo-has-mega:hover > .pmo-mega-panel {
  display: block;
}

/* Group columns inside mega panel (one per ProcessGroup) */
.pmo-mega-groups {
  display: flex;
  flex-wrap: nowrap;
  gap: 18px;
}

/* Each Process Group column */
.pmo-mega-group {
  min-width: 130px;
}

/* Process Group title */
.pmo-mega-group-title {
  font-size: 13px;
  font-weight: 700;
  color: #2F5597;
  margin-bottom: 6px;
  border-bottom: 1px solid #dde2ee;
  padding-bottom: 3px;
}

/* Knowledge Area sections inside each Process Group */
.pmo-mega-area {
  margin-bottom: 10px;
}

.pmo-mega-area-title {
  font-size: 12px;
  font-weight: 600;
  color: #333;
  margin-bottom: 2px;
}

/* List of templates inside a Knowledge Area */
.pmo-mega-area-items {
  list-style: none;
  margin: 0;
  padding: 0;
}

.pmo-mega-area-items li a {
  display: block;
  font-size: 12px;
  color: #444;
  text-decoration: none;
  padding: 2px 0;
}

.pmo-mega-area-items li a:hover {
  text-decoration: underline;
}

/* ====== RESPONSIVE TWEAKS ====== */

@media (max-width: 768px) {
  .pmo-main-nav-root {
    flex-wrap: wrap;
    gap: 10px;
  }

  .pmo-main-nav-root > li.pmo-has-mega {
    position: static;
  }

  .pmo-mega-panel {
    position: static;
    box-shadow: none;
    border-radius: 0;
    margin-top: 6px;
    min-width: auto;
    max-width: none;
  }

  .pmo-mega-groups {
    flex-direction: column;
  }
}




// v3 - Uses Title + NavArea, no IsTopLevel needed
function InitPMOMegaMenu() {
  try {
    console.log("PMO MegaMenu v3: Init starting...");

    var navContainer = document.getElementById("pmoMegaNav");
    if (!navContainer) {
      console.warn("PMO MegaMenu v3: #pmoMegaNav not found on page.");
      return;
    }

    // Site URL
    var siteUrl = (typeof _spPageContextInfo !== "undefined" && _spPageContextInfo.webAbsoluteUrl)
      ? _spPageContextInfo.webAbsoluteUrl
      : window.location.origin + window.location.pathname.replace(/\/Pages\/.*/i, "");

    var listTitle = "Navigation";

    // NOTE: "URL" must match the internal name of your hyperlink column
    var requestUrl = siteUrl +
      "/_api/web/lists/getbytitle('" + listTitle + "')/items" +
      "?$select=Id,Title,URL,NavArea,ProcessGroup,KnowledgeArea,SortOrder" +
      "&$orderby=SortOrder,Title";

    console.log("PMO MegaMenu v3: REST URL =", requestUrl);

    function getJSON(url, onSuccess, onError) {
      var xhr = new XMLHttpRequest();
      xhr.open("GET", url, true);
      xhr.setRequestHeader("Accept", "application/json;odata=nometadata");
      xhr.onreadystatechange = function () {
        if (xhr.readyState !== 4) return;
        if (xhr.status >= 200 && xhr.status < 300) {
          try {
            var data = JSON.parse(xhr.responseText);
            onSuccess(data);
          } catch (e) {
            console.error("PMO MegaMenu v3: JSON parse error", e);
            if (onError) onError(e);
          }
        } else {
          console.error("PMO MegaMenu v3: HTTP", xhr.status, xhr.statusText);
          if (onError) onError(xhr.statusText);
        }
      };
      xhr.send();
    }

    function groupBy(arr, fn) {
      var map = {};
      (arr || []).forEach(function (item) {
        var key = fn(item) || "";
        if (!map[key]) map[key] = [];
        map[key].push(item);
      });
      return map;
    }

    function getUrlFromField(field) {
      if (!field) return "#";
      if (typeof field === "string") return field;
      if (field.Url) return field.Url;
      if (field.url) return field.url;
      return "#";
    }

    // ---------------------------
    // Templates mega-menu builder
    // ---------------------------
    function buildTemplatesPanel(children) {
      var byProcess = groupBy(children, function (i) { return i.ProcessGroup; });

      var panel = document.createElement("div");
      panel.className = "pmo-mega-panel";

      var wrapper = document.createElement("div");
      wrapper.className = "pmo-mega-groups";

      Object.keys(byProcess).sort().forEach(function (pg) {
        var pgItems = byProcess[pg];
        if (!pgItems.length) return;

        var pgDiv = document.createElement("div");
        pgDiv.className = "pmo-mega-group";

        var pgTitle = document.createElement("div");
        pgTitle.className = "pmo-mega-group-title";
        pgTitle.textContent = pg || "Other";
        pgDiv.appendChild(pgTitle);

        var byKA = groupBy(pgItems, function (i) { return i.KnowledgeArea; });

        Object.keys(byKA).sort().forEach(function (ka) {
          var kaItems = byKA[ka];
          if (!kaItems.length) return;

          var kaDiv = document.createElement("div");
          kaDiv.className = "pmo-mega-area";

          var kaTitle = document.createElement("div");
          kaTitle.className = "pmo-mega-area-title";
          kaTitle.textContent = ka || "General";
          kaDiv.appendChild(kaTitle);

          var ul = document.createElement("ul");
          ul.className = "pmo-mega-area-items";

          kaItems.forEach(function (t) {
            var urlVal = getUrlFromField(t.URL);
            var li = document.createElement("li");

            var a = document.createElement("a");
            a.href = urlVal;
            a.textContent = t.Title || urlVal;

            li.appendChild(a);
            ul.appendChild(li);
          });

          kaDiv.appendChild(ul);
          pgDiv.appendChild(kaDiv);
        });

        wrapper.appendChild(pgDiv);
      });

      panel.appendChild(wrapper);
      return panel;
    }

    // ---------------------------
    // Main nav builder
    // ---------------------------
    function buildNav(items) {
      console.log("PMO MegaMenu v3: item count =", items.length);
      if (!items.length) {
        navContainer.innerHTML =
          "<div style='color:red;padding:6px'>Navigation list '" + listTitle + "' has no items.</div>";
        return;
      }

      // Separate Templates children vs general top-level items.
      var topLevel = [];
      var templatesChildren = [];

      items.forEach(function (i) {
        var area = i.NavArea;

        if (area === "Templates" && i.Title !== "Templates") {
          // Anything in Templates area that isn't the main "Templates" row is a child
          templatesChildren.push(i);
        } else {
          // Methodology, Training, Governance, etc. + the main Templates row
          topLevel.push(i);
        }
      });

      if (!topLevel.length) {
        navContainer.innerHTML =
          "<div style='color:red;padding:6px'>No top-level items determined. " +
          "Ensure you have at least a 'Templates' row and a 'Methodology' row.</div>";
        return;
      }

      var byArea = groupBy(items, function (i) { return i.NavArea; });

      // Build the nav container
      var nav = document.createElement("nav");
      nav.className = "pmo-main-nav";
      // Make it visible even if external CSS isn't loaded
      nav.style.background = "#2F5597";
      nav.style.padding = "0 16px";

      var ul = document.createElement("ul");
      ul.className = "pmo-main-nav-root";
      ul.style.listStyle = "none";
      ul.style.margin = "0";
      ul.style.padding = "0";
      ul.style.display = "flex";
      ul.style.gap = "18px";

      topLevel.forEach(function (top) {
        var area = top.NavArea;
        var li = document.createElement("li");

        var urlVal = getUrlFromField(top.URL);

        var a = document.createElement("a");
        a.href = urlVal;
        a.textContent = top.Title || area;
        a.style.display = "block";
        a.style.padding = "10px 4px";
        a.style.color = "#ffffff";
        a.style.textDecoration = "none";
        a.style.fontSize = "14px";
        a.style.fontWeight = "500";

        li.appendChild(a);

        // If this is the Templates top-level item, attach the mega panel
        if (area === "Templates" && templatesChildren.length) {
          li.className = "pmo-has-mega";
          li.appendChild(buildTemplatesPanel(templatesChildren));
        }

        ul.appendChild(li);
      });

      nav.appendChild(ul);
      navContainer.innerHTML = "";
      navContainer.appendChild(nav);
    }

    // Fetch items and build nav
    getJSON(requestUrl, function (data) {
      var items = data && data.value ? data.value : [];
      console.log("PMO MegaMenu v3: raw items sample =", items[0]);
      buildNav(items);
    }, function (err) {
      console.error("PMO MegaMenu v3: error loading list '" + listTitle + "':", err);
      navContainer.innerHTML =
        "<div style='color:red;padding:6px'>Error loading list '" + listTitle + "'.</div>";
    });

  } catch (ex) {
    console.error("PMO MegaMenu v3: fatal error", ex);
  }
}

// SharePoint load hookup
if (typeof _spBodyOnLoadFunctionNames !== "undefined") {
  _spBodyOnLoadFunctionNames.push("InitPMOMegaMenu");
}
if (typeof RegisterModuleInit === "function") {
  RegisterModuleInit(
    "~sitecollection/Style Library/PMO/Navigation/megamenu.js",
    InitPMOMegaMenu
  );
}


function InitPMOMegaMenu() {
  console.log("InitPMOMegaMenu: basic test starting");

  var navContainer = document.getElementById("pmoMegaNav");
  if (!navContainer) {
    console.warn("InitPMOMegaMenu: #pmoMegaNav not found");
    return;
  }

  // Simple hard-coded nav bar (no REST, no list)
  navContainer.innerHTML =
    '<nav class="pmo-main-nav" style="background:#2F5597;padding:0 16px;">' +
      '<ul class="pmo-main-nav-root" style="list-style:none;margin:0;padding:0;display:flex;gap:18px;">' +
        '<li><a href="#" style="display:block;padding:10px 4px;color:#fff;text-decoration:none;font-size:14px;font-weight:500;">Test</a></li>' +
        '<li><a href="#" style="display:block;padding:10px 4px;color:#fff;text-decoration:none;font-size:14px;font-weight:500;">Templates</a></li>' +
      '</ul>' +
    '</nav>';

  console.log("InitPMOMegaMenu: basic nav written");
}

// Wire it into SharePoint's page-load pipeline
if (typeof _spBodyOnLoadFunctionNames !== "undefined") {
  _spBodyOnLoadFunctionNames.push("InitPMOMegaMenu");
}

if (typeof RegisterModuleInit === "function") {
  RegisterModuleInit(
    "~sitecollection/Style Library/PMO/Navigation/megamenu.js",
    InitPMOMegaMenu
  );
}

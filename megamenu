// /Style Library/PMO/Navigation/megamenu.js
// Phase 1: simple flat nav driven by the "Navigation" list (Title, URL, SortOrder)

function InitPMOMegaMenu() {
  try {
    console.log("PMO SimpleNav: InitPMOMegaMenu starting...");

    var navContainer = document.getElementById("pmoMegaNav");
    if (!navContainer) {
      console.warn("PMO SimpleNav: #pmoMegaNav not found on page.");
      return;
    }

    // Use _spPageContextInfo if available, otherwise fall back
    var siteUrl = (typeof _spPageContextInfo !== "undefined" && _spPageContextInfo.webAbsoluteUrl)
      ? _spPageContextInfo.webAbsoluteUrl
      : window.location.origin + window.location.pathname.replace(/\/Pages\/.*/i, "");

    // Your list is named "Navigation"
    var listTitle = "Navigation";

    // We keep it minimal: Title, URL, SortOrder
    // NOTE: "URL" here must match the INTERNAL NAME of your hyperlink column
    var requestUrl = siteUrl +
      "/_api/web/lists/getbytitle('" + listTitle + "')/items" +
      "?$select=Id,Title,URL,SortOrder" +
      "&$orderby=SortOrder,Title";

    console.log("PMO SimpleNav: siteUrl =", siteUrl);
    console.log("PMO SimpleNav: REST URL =", requestUrl);

    function getJSON(url, onSuccess, onError) {
      var xhr = new XMLHttpRequest();
      xhr.open("GET", url, true);
      xhr.setRequestHeader("Accept", "application/json;odata=nometadata");
      xhr.onreadystatechange = function () {
        if (xhr.readyState !== 4) return;
        if (xhr.status >= 200 && xhr.status < 300) {
          try {
            var data = JSON.parse(xhr.responseText);
            onSuccess(data);
          } catch (e) {
            console.error("PMO SimpleNav: JSON parse error", e);
            if (onError) onError(e);
          }
        } else {
          console.error("PMO SimpleNav: HTTP error", xhr.status, xhr.statusText);
          if (onError) onError(xhr.statusText || ("HTTP " + xhr.status));
        }
      };
      xhr.send();
    }

    function buildNav(items) {
      console.log("PMO SimpleNav: item count =", items.length);
      console.log("PMO SimpleNav: items sample =", items[0]);

      if (!items || !items.length) {
        navContainer.innerHTML =
          "<div style='color:red; padding:6px 0; font-size:12px;'>" +
            "Navigation list '<strong>" + listTitle + "</strong>' returned no items.<br/>" +
            "Add some rows with Title, URL, and optional SortOrder." +
          "</div>";
        return;
      }

      // Create nav container
      var navEl = document.createElement("nav");
      navEl.className = "pmo-main-nav";
      // Ensure visible even without external CSS
      navEl.style.background = "#2F5597";
      navEl.style.padding = "0 16px";

      var ulRoot = document.createElement("ul");
      ulRoot.className = "pmo-main-nav-root";
      ulRoot.style.listStyle = "none";
      ulRoot.style.margin = "0";
      ulRoot.style.padding = "0";
      ulRoot.style.display = "flex";
      ulRoot.style.gap = "18px";

      items.forEach(function (item) {
        var li = document.createElement("li");

        var a = document.createElement("a");
        var urlVal;

        // With odata=nometadata, hyperlink column often comes back as a simple string
        // If it's something else, log it
        if (typeof item.URL === "string") {
          urlVal = item.URL;
        } else if (item.URL && typeof item.URL === "object") {
          // Just in case it's an object, try a Url property
          urlVal = item.URL.Url || item.URL.url || "#";
        } else {
          urlVal = "#";
        }

        a.href = urlVal;
        a.textContent = item.Title || urlVal;

        // Basic styling inline so we can see it even if CSS isn't wired yet
        a.style.display = "block";
        a.style.padding = "10px 4px";
        a.style.color = "#ffffff";
        a.style.textDecoration = "none";
        a.style.fontSize = "14px";
        a.style.fontWeight = "500";

        li.appendChild(a);
        ulRoot.appendChild(li);
      });

      navEl.appendChild(ulRoot);
      navContainer.innerHTML = "";
      navContainer.appendChild(navEl);
    }

    // Kick off REST call
    getJSON(requestUrl, function (data) {
      var items = (data && data.value) ? data.value : [];
      buildNav(items);
    }, function (err) {
      console.error("PMO SimpleNav: error loading list '" + listTitle + "':", err);
      navContainer.innerHTML =
        "<div style='color:red; padding:6px 0; font-size:12px;'>" +
          "Error loading navigation from list '<strong>" + listTitle + "</strong>'. " +
          "Check browser console for details." +
        "</div>";
    });

  } catch (ex) {
    console.error("PMO SimpleNav: unexpected error in InitPMOMegaMenu", ex);
  }
}

// Wire into SharePoint's load pipeline (this part was already working)
if (typeof _spBodyOnLoadFunctionNames !== "undefined") {
  _spBodyOnLoadFunctionNames.push("InitPMOMegaMenu");
}

if (typeof RegisterModuleInit === "function") {
  RegisterModuleInit(
    "~sitecollection/Style Library/PMO/Navigation/megamenu.js",
    InitPMOMegaMenu
  );
}

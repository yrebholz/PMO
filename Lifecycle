<!-- PMO Methodology Visual Toggle Component -->
<style>
  .pmo-visual-method-wrapper {
    max-width: 1100px;
    margin: 0 auto;
    font-family: "Segoe UI", Arial, sans-serif;
    background: #ffffff;
    border-radius: 10px;
    border: 1px solid #dde2ee;
    padding: 22px 24px 26px;
    box-sizing: border-box;
  }

  .pmo-visual-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }

  .pmo-visual-title {
    font-size: 20px;
    font-weight: 600;
    color: #222;
  }

  .pmo-visual-subtitle {
    font-size: 12px;
    color: #666;
  }

  .pmo-toggle {
    display: inline-flex;
    border-radius: 20px;
    border: 1px solid #c3cadc;
    overflow: hidden;
    background: #f5f6fa;
  }

  .pmo-toggle button {
    border: none;
    padding: 8px 16px;
    font-size: 13px;
    cursor: pointer;
    background: transparent;
    color: #555;
    font-weight: 500;
    white-space: nowrap;
  }

  .pmo-toggle button.active {
    background: #033161; /* PMO navy */
    color: #fff;
  }

  /* Visual track – base layout (shared by both methods) */
  .pmo-track-container {
    position: relative;
    margin-top: 8px;
    padding: 22px 16px 10px;
    border-radius: 12px;
    /* background is now mode-specific */
    overflow: hidden;
  }

  .pmo-track-background-line {
    position: absolute;
    left: 5%;
    right: 5%;
    top: 50%;
    height: 6px;
    border-radius: 999px;
    /* background is now mode-specific */
    z-index: 1;
  }

  .pmo-track {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    z-index: 2;
  }

  .pmo-node {
    text-align: center;
    max-width: 150px;
    flex: 1 1 0;
  }

  .pmo-node-circle {
    width: 56px;
    height: 56px;
    margin: 0 auto 8px;
    border-radius: 50%;
    background: #ffffff;
    border: 3px solid transparent; /* color is mode-specific */
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    color: inherit; /* color is mode-specific */
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
  }

  .pmo-node-label {
    font-size: 14px;
    font-weight: 600;
    color: #222;
    margin-bottom: 4px;
  }

  .pmo-node-subtitle {
    font-size: 11px;
    color: #555;
    line-height: 1.3;
  }

  /* Prevent SharePoint buttons from shifting */
  input[type=button],
  input[type=reset],
  input[type=submit],
  button {
    margin-left: 0px;
  }

  /* -------------------- MODE-SPECIFIC STYLES -------------------- */

  /* Waterfall mode (blue) */
  .mode-waterfall .pmo-track-container {
    background: linear-gradient(135deg, #f7f9fc, #eef2fa);
  }

  .mode-waterfall .pmo-track-background-line {
    background: rgba(3, 49, 97, 0.16);
  }

  .mode-waterfall .pmo-node-circle {
    border-color: #033161;
    color: #033161;
  }

  /* Agile style variant (green) */
  .mode-agile .pmo-track-container {
    background: linear-gradient(135deg, #f5fdf9, #e7f7f1);
  }

  .mode-agile .pmo-track-background-line {
    background: linear-gradient(90deg, #0e7c7b, #1a9a5a);
  }

  .mode-agile .pmo-node-circle {
    border-color: #0e7c7b;
    color: #0e7c7b;
  }

  /* Hidden/visible tracks */
  .pmo-track.waterfall-track {
    display: flex;
  }

  .pmo-track.agile-track {
    display: none;
  }

  .mode-agile .waterfall-track {
    display: none;
  }

  .mode-agile .agile-track {
    display: flex;
  }

  /* Legend text */
  .pmo-legend {
    margin-top: 10px;
    font-size: 11px;
    color: #555;
  }

  .pmo-legend strong {
    color: #033161;
  }

  .pmo-legend span.badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 10px;
    margin-right: 6px;
  }

  .badge-waterfall {
    background: #e7f0ff;
    color: #033161;
    border: 1px solid #c0cfee;
  }

  .badge-agile {
    background: #e3f8ef;
    color: #0e7c7b;
    border: 1px solid #a9e4cf;
  }

  /* Lessons Learned ribbon */
  .pmo-lessons-ribbon {
    margin-top: 14px;
    padding: 8px 10px;
    border-radius: 6px;
    background: #fff;
    border: 1px dashed #c0cfee;
    font-size: 11px;
    color: #444;
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .pmo-lessons-icon {
    font-size: 16px;
    line-height: 1;
  }

  .pmo-lessons-text strong {
    color: #033161;
  }

  /* Responsive tweaks */
  @media (max-width: 768px) {
    .pmo-visual-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .pmo-track {
      flex-direction: column;
      align-items: center;
    }

    .pmo-track-background-line {
      display: none;
    }

    .pmo-node {
      max-width: none;
      width: 100%;
      display: flex;
      align-items: center;
      text-align: left;
      gap: 10px;
    }

    .pmo-node-circle {
      margin: 0;
    }

    .pmo-node-label {
      font-size: 13px;
    }
  }
</style>

<div id="pmoVisualMethod" class="pmo-visual-method-wrapper mode-waterfall">
  <div class="pmo-visual-header">
    <div>
      <div class="pmo-visual-title">Project Delivery Lifecycle</div>
      <div class="pmo-visual-subtitle" id="pmoVisualSubtitle">
        Viewing: <strong>Waterfall (PMI process groups)</strong>. Use the toggle
        to switch to the Agile / iterative view.
      </div>
    </div>
    <div class="pmo-toggle">
      <button id="btnVMWaterfall" type="button" class="active">Waterfall (PMI)</button>
      <button id="btnVMAgile">Agile / Iterative</button>
    </div>
  </div>

  <div class="pmo-track-container">
    <div class="pmo-track-background-line"></div>

    <!-- WATERFALL TRACK -->
    <div class="pmo-track waterfall-track">
      <div class="pmo-node">
        <div class="pmo-node-circle">1</div>
        <div class="pmo-node-label">Initiation</div>
        <div class="pmo-node-subtitle">
          Define the problem or opportunity, sponsor, and high-level scope.
        </div>
      </div>

      <div class="pmo-node">
        <div class="pmo-node-circle">2</div>
        <div class="pmo-node-label">Planning</div>
        <div class="pmo-node-subtitle">
          Build the plan: requirements, schedule, risks, governance, and
          communications.
        </div>
      </div>

      <div class="pmo-node">
        <div class="pmo-node-circle">3</div>
        <div class="pmo-node-label">Execution</div>
        <div class="pmo-node-subtitle">
          Deliver the approved scope, coordinate teams, and manage suppliers.
        </div>
      </div>

      <div class="pmo-node">
        <div class="pmo-node-circle">4</div>
        <div class="pmo-node-label">Monitoring &amp; Controlling</div>
        <div class="pmo-node-subtitle">
          Track progress, manage changes, escalate risks, and report status.
        </div>
      </div>

      <div class="pmo-node">
        <div class="pmo-node-circle">5</div>
        <div class="pmo-node-label">Closure</div>
        <div class="pmo-node-subtitle">
          Formal acceptance, hand-off to operations, and end-of-project
          review.
        </div>
      </div>
    </div>

    <!-- AGILE TRACK -->
    <div class="pmo-track agile-track">
      <div class="pmo-node">
        <div class="pmo-node-circle">1</div>
        <div class="pmo-node-label">Discovery / Vision</div>
        <div class="pmo-node-subtitle">
          Clarify product vision, outcomes, stakeholders, and high-level scope.
        </div>
      </div>

      <div class="pmo-node">
        <div class="pmo-node-circle">2</div>
        <div class="pmo-node-label">Backlog &amp; Planning</div>
        <div class="pmo-node-subtitle">
          Build and refine a prioritized backlog and plan the next iteration.
        </div>
      </div>

      <div class="pmo-node">
        <div class="pmo-node-circle">3</div>
        <div class="pmo-node-label">Iteration / Sprint</div>
        <div class="pmo-node-subtitle">
          Timeboxed delivery with daily stand-ups and ongoing refinement.
        </div>
      </div>

      <div class="pmo-node">
        <div class="pmo-node-circle">4</div>
        <div class="pmo-node-label">Review / Acceptance</div>
        <div class="pmo-node-subtitle">
          Demonstrate working increments and confirm acceptance criteria.
        </div>
      </div>

      <div class="pmo-node">
        <div class="pmo-node-circle">5</div>
        <div class="pmo-node-label">Retrospective</div>
        <div class="pmo-node-subtitle">
          Inspect ways of working, capture improvements, and feed the next
          cycle.
        </div>
      </div>
    </div>
  </div>

  <div class="pmo-legend">
    <span class="badge badge-waterfall">Waterfall</span>
    <span class="badge badge-agile">Agile</span>
    <span>
      Each numbered step aligns across both views (1 = Start/Vision, 2 =
      Planning, 3 = Delivery, 4 = Validation, 5 = Close/Improve).
    </span>
  </div>

  <div class="pmo-lessons-ribbon">
    <div class="pmo-lessons-icon">💡</div>
    <div class="pmo-lessons-text">
      <strong>Lessons Learned apply to both lifecycles.</strong> In Waterfall,
      they are captured during project Closure. In Agile, they are captured
      every Retrospective and rolled into continuous improvement. Link this
      panel to your Lessons Learned library or submission form.
    </div>
  </div>
</div>

<script type="text/javascript">
  (function () {
    var wrapper = document.getElementById("pmoVisualMethod");
    if (!wrapper) return;

    var btnWF = document.getElementById("btnVMWaterfall");
    var btnAg = document.getElementById("btnVMAgile");
    var subtitle = document.getElementById("pmoVisualSubtitle");

    function setMode(mode) {
      // reset mode classes
      var baseClass = "pmo-visual-method-wrapper";
      wrapper.className = baseClass + (mode === "agile" ? " mode-agile" : " mode-waterfall");

      if (mode === "waterfall") {
        btnWF.className = "active";
        btnAg.className = "";
        if (subtitle) {
          subtitle.innerHTML =
            'Viewing: <strong>Waterfall (PMI process groups)</strong>. Use the toggle to switch to the Agile / iterative view.';
        }
      } else {
        btnWF.className = "";
        btnAg.className = "active";
        if (subtitle) {
          subtitle.innerHTML =
            'Viewing: <strong>Agile / iterative lifecycle</strong>. Use the toggle to switch back to the Waterfall (PMI) view.';
        }
      }
    }

if (btnWF) btnWF.onclick = function (e) {
  if (e && e.preventDefault) e.preventDefault();
  setMode("waterfall");
};

if (btnAg) btnAg.onclick = function (e) {
  if (e && e.preventDefault) e.preventDefault();
  setMode("agile");
};

    // Default state
    setMode("waterfall");
  })();
</script>
